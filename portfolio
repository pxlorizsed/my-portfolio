<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Evwin Mathew</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;700&family=Space+Mono&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    background:#f5f5f3;
    color:#111;
    overflow-x:hidden;
}

/* NAVBAR */

nav{
    width:100%;
    position:fixed;
    top:0;
    left:0;
    display:flex;
    justify-content:flex-end;
    padding:40px 80px;
    z-index:1000;
    background:rgba(245,245,243,0.75);
    backdrop-filter:blur(8px);
}

nav ul{
    display:flex;
    gap:70px;
    list-style:none;
}

nav a{
    text-decoration:none;
    color:#444;
    font-family:'Space Mono', monospace;
    font-size:18px;
    letter-spacing:3px;
    transition:0.3s;
}

nav a:hover{
    color:#2147ff;
}

/* HERO */

.hero{
    min-height:100vh;
    padding:120px 60px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    position:relative;
}

.left{
    width:50%;
}

.small-text{
    font-family:'Space Mono', monospace;
    letter-spacing:4px;
    font-size:20px;
    color:#5b5b5b;
    margin-bottom:25px;
}

.main-title{
    font-family:'Cormorant Garamond', serif;
    font-size:130px;
    line-height:0.9;
    font-weight:700;
}

.scroll{
    margin-top:90px;
    font-family:'Space Mono', monospace;
    letter-spacing:3px;
    color:#555;
    font-size:20px;
}

.right{
    width:40%;
    display:flex;
    justify-content:flex-end;
}

.statement{
    font-family:'Space Mono', monospace;
    color:#2147ff;
    letter-spacing:4px;
    font-size:22px;
}

/* PROJECTS */

.section{
    padding:120px 70px;
}

.section-title{
    font-family:'Space Mono', monospace;
    letter-spacing:5px;
    font-size:25px;
    margin-bottom:60px;
}

.projects-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(350px,1fr));
    gap:50px;
}

.project-card{
    transition:0.4s;
}

.project-card:hover{
    transform:translateY(-10px);
}

.project-card img{
    width:100%;
    height:350px;
    object-fit:cover;
    filter:grayscale(100%);
    transition:0.4s;
}

.project-card img:hover{
    filter:grayscale(0%);
}

.project-info{
    margin-top:25px;
}

.project-info h2{
    font-family:'Cormorant Garamond', serif;
    font-size:45px;
    margin-bottom:15px;
}

.project-info p{
    font-family:'Space Mono', monospace;
    line-height:1.8;
    color:#555;
}

/* DOCUMENTS */

.documents-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:30px;
}

.document-card{
    border:1px solid #ddd;
    padding:40px;
    background:white;
    transition:0.3s;
}

.document-card:hover{
    border-color:#2147ff;
    transform:translateY(-5px);
}

.document-card h3{
    font-family:'Cormorant Garamond', serif;
    font-size:35px;
    margin-bottom:15px;
}

.document-card a{
    text-decoration:none;
    color:#2147ff;
    font-family:'Space Mono', monospace;
    letter-spacing:2px;
}

/* EXPERIENCE */

.experience{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:50px;
}

.experience-card{
    padding:60px;
    background:white;
    border:1px solid #ddd;
}

.experience-card h2{
    font-family:'Cormorant Garamond', serif;
    font-size:50px;
    margin-bottom:25px;
}

.experience-card p{
    font-family:'Space Mono', monospace;
    line-height:2;
    color:#555;
}

/* CONTACT */

.contact{
    text-align:center;
    padding-bottom:100px;
}

.contact h1{
    font-family:'Cormorant Garamond', serif;
    font-size:90px;
    margin-bottom:30px;
}

.contact p{
    font-family:'Space Mono', monospace;
    letter-spacing:3px;
}

@media(max-width:900px){

    .hero{
        flex-direction:column;
        justify-content:center;
        gap:100px;
    }

    .left,
    .right{
        width:100%;
    }

    .main-title{
        font-size:90px;
    }

    .experience{
        grid-template-columns:1fr;
    }

    nav{
        justify-content:center;
        padding:30px;
    }

    nav ul{
        gap:30px;
    }

}

</style>
</head>

